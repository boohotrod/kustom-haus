# =============================================================================
# BBS AI Builder — environment variables (example)
# -----------------------------------------------------------------------------
# Copy this file to `.env` (local dev) or set the variables in cPanel →
# Setup Node.js App → Environment variables (production / staging).
#
# NEVER commit a real .env file. Only `.env.example` belongs in the repo.
# The Builder Core v0.2 preview runs without ANY of these set (mock-store mode).
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production
# Port that the TanStack Start/Nitro server binds to.
# On cPanel Passenger this is provided automatically — leave unset there.
PORT=3000

# ---- Database (B-3+, NOT used in v0.2 preview) ------------------------------
# MySQL connection string for Drizzle. Format:
#   mysql://USER:PASSWORD@HOST:3306/DBNAME
DATABASE_URL=

# ---- Session / crypto (generate with: openssl rand -hex 32) -----------------
SESSION_SECRET=
INVITE_SIGNING_KEY=
AUDIT_CHAIN_SECRET=
FEDERATION_SIGNING_KEY=

# ---- AI providers (optional, only when a real provider is activated) --------
AI_GATEWAY_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ---- Public (browser) config — must be prefixed with VITE_ ------------------
# Read in client code via import.meta.env.VITE_*
# VITE_PUBLIC_SITE_NAME="BBS Builder"
